# ================================================================
# .env.local template for heard-apol-ai (Next.js app)
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ================================================================

# ---------------------------------------------------------------
# Supabase
# Get from: Supabase Dashboard → Project Settings → API
# Use NEW key format only — never legacy eyJ... JWT keys
# ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ---------------------------------------------------------------
# App base URL
# Local dev: http://localhost:3000  |  Production: https://heard.apol.ai
# ---------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------
# Google Cloud — for triggering the Cloud Run Job from webhooks
# ---------------------------------------------------------------
GOOGLE_CLOUD_PROJECT=heard-apol-ai
CLOUD_RUN_JOB_NAME=heard-agent
CLOUD_RUN_JOB_REGION=us-central1

# ---------------------------------------------------------------
# Shopify Partner app — for merchant OAuth (connect store flow)
# Get from: partners.shopify.com → Apps → <your app> → Client credentials
# SHOPIFY_API_KEY = Client ID   |   SHOPIFY_API_SECRET = Client secret
# ---------------------------------------------------------------
SHOPIFY_API_KEY=your-shopify-client-id
SHOPIFY_API_SECRET=your-shopify-client-secret

# ---------------------------------------------------------------
# Demo account — hackathon judge login bypass (server-side only)
# Never use NEXT_PUBLIC_ prefix — must stay out of the client bundle
# ---------------------------------------------------------------
DEMO_ACCOUNT_EMAIL=

# ---------------------------------------------------------------
# Google OAuth — for Google Business Profile connection
# GCP Console → APIs & Services → Credentials → OAuth 2.0 Client
# Authorized redirect URI must be: <NEXT_PUBLIC_APP_URL>/api/auth/google/callback
# ---------------------------------------------------------------
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ---------------------------------------------------------------
# Internal secrets
# Generate with: openssl rand -hex 32
# ---------------------------------------------------------------
INTERNAL_AGENT_TRIGGER_SECRET=replace-with-random-32-byte-hex
